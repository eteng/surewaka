{
  "name": "@surewaka/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "db:pull": "drizzle-kit pull && cp drizzle/schema.ts src/schema.ts && perl -i -pe \"s/\\{ withTimezone: true, mode: 'string' \\}/{ withTimezone: true }/g; s/, \\{ mode: 'string' \\}//g\" src/schema.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
