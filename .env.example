# =============================================================================
# Supabase (Database + Auth + Storage + Realtime)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Direct Postgres connection (for Drizzle ORM migrations and server-side queries)
# Use the "Connection string" from Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Pooled connection (for high-concurrency server usage)
DATABASE_POOL_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AI / LLM
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# =============================================================================
# Payments (Paystack for Nigeria)
# =============================================================================
PAYSTACK_SECRET_KEY=sk_test_your-paystack-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-key

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=re_your-resend-key

# =============================================================================
# Landing Page — Pre-Launch Access Protection
# =============================================================================
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USER=surewaka
BASIC_AUTH_PASSWORD=changeme

# =============================================================================
# App URLs
# =============================================================================
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
