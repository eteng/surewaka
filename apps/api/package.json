    "@surewaka/auth": "workspace:*",
    "@surewaka/realtime": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.23.0",
    "cloudinary": "^2.5.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
